{
  "buildCommand": "npm run build:edgeone",
  "outputDirectory": "dist",
  "nodeVersion": "20.18.0",
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/dashboard.html",
      "statusCode": 302
    },
    {
      "source": "/embed",
      "destination": "/embed.html",
      "statusCode": 302
    },
    {
      "source": "/settings",
      "destination": "/settings.html",
      "statusCode": 302
    },
    {
      "source": "/mcp-grant",
      "destination": "/mcp-grant.html",
      "statusCode": 302
    },
    {
      "source": "/live-channels",
      "destination": "/live-channels.html",
      "statusCode": 302
    }
  ],
  "headers": [
    {
      "source": "/assets/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/dashboard.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, must-revalidate"
        }
      ]
    }
  ]
}
